rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'name', 'totalCo2Saved', 'totalEcoPoints', 'createdAt']) &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'totalCo2Saved', 'totalEcoPoints', 'activeVehicleId']);

      // Vehicles subcollection
      match /vehicles/{vehicleId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(vehicleId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Trips subcollection
      match /trips/{tripId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(tripId);
      }
    }

    // Leaderboard
    match /leaderboard/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // System only updates this via admin SDK or internal triggers
    }
  }
}
